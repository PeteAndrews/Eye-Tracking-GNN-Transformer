# Raw data (read-only inputs; never commit)
_data/

# Pipeline and experiment outputs
data_processed/
runs/
artifacts/*.pt
artifacts/**/*.pt
!artifacts/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/

# Conda / local env artefacts
.conda/
*.conda

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# MLflow / trackers
mlruns/
wandb/

# Notebooks checkpoints
.ipynb_checkpoints/

# Local temp
*.tmp
*.log
.cache/

# Gate 1/2 visual check HTMLs (large; regenerate with scripts/gaze_overlay_check.py)
reports/gaze_checks/**/*.html
reports/gaze_checks/**/*.png
!reports/gaze_checks/**/.gitkeep
